@model DashboardViewModel

@{
    ViewData["Title"] = "Quản Lý Công Nợ";
    var today = Model.NgayHienTai;
    var todayIso = today.ToString("yyyy-MM-dd");
}

<!-- BÁO CÁO TỔNG HỢP -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-primary h-100">
            <div class="card-body text-center">
                <h6 class="card-title text-muted">Tổng nợ (gốc + mới)</h6>
                <h3 class="text-primary">@Model.TongNo.ToString("#,##0") đ</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-success h-100">
            <div class="card-body text-center">
                <h6 class="card-title text-muted">Tổng đã trả</h6>
                <h3 class="text-success">@Model.TongTra.ToString("#,##0") đ</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-danger h-100">
            <div class="card-body text-center">
                <h6 class="card-title text-muted">Tổng còn nợ</h6>
                <h3 class="text-danger">@Model.TongConNo.ToString("#,##0") đ</h3>
            </div>
        </div>
    </div>
</div>

<!-- CHỌN NGÀY & EXCEL -->
<div class="d-flex flex-wrap align-items-center gap-2 mb-3">
    <form method="get" class="d-flex align-items-center gap-2">
        <label class="fw-bold">Ngày:</label>
        <input type="date" name="ngay" value="@today.ToString("yyyy-MM-dd")" class="form-control form-control-sm" style="width:170px" onchange="this.form.submit()" />
    </form>
    <div class="ms-auto d-flex gap-1">
        <div class="dropdown">
            <button class="btn btn-sm btn-outline-success dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-download"></i> Export
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/Home/ExportExcel?loai=today">Giao dịch hôm nay</a></li>
                <li><a class="dropdown-item" href="/Home/ExportExcel?loai=all">Tất cả giao dịch</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" href="/Home/ExportBaoCao">Báo cáo công nợ (7 ngày)</a></li>
            </ul>
        </div>
        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#importModal">
            <i class="bi bi-upload"></i> Import Excel
        </button>
        <button class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#khachHangModal">
            <i class="bi bi-person-plus"></i> Thêm khách
        </button>
        <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteAllModal">
            <i class="bi bi-trash3"></i> Xóa toàn bộ
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- 3 TABS -->
<ul class="nav nav-tabs" id="mainTabs" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-no-moi" type="button">
            <i class="bi bi-plus-circle"></i> Nhập nợ hôm nay
            <span class="badge bg-primary">@Model.NoMoiHomNay.Count</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-tra-no" type="button">
            <i class="bi bi-cash-stack"></i> Trả nợ hôm nay
            <span class="badge bg-success">@Model.NoTraHomNay.Count</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-con-lai" type="button">
            <i class="bi bi-exclamation-triangle"></i> Tổng nợ theo khách
            <span class="badge bg-danger">@Model.ThongKeNoTheoKhach.Count</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-hoan-thien" type="button" id="btn-tab-hoan-thien">
            <i class="bi bi-images"></i> Hoàn thiện dữ liệu
        </button>
    </li>
</ul>

<div class="tab-content border border-top-0 rounded-bottom p-3">
    <!-- TAB 1: NỢ MỚI HÔM NAY -->
    <div class="tab-pane fade show active" id="tab-no-moi">
        <h5 class="mb-3">Nhập nợ mới - @today.ToString("dd/MM/yyyy")</h5>

        <form asp-action="ThemGiaoDich" method="post" class="row g-2 mb-3 align-items-end bg-light p-3 rounded excel-grid">
            <input type="hidden" name="Ngay" value="@today.ToString("yyyy-MM-dd")" />
            <div class="col-md-2">
                <label class="form-label small">Lái (khách bán)</label>
                <input type="text" name="TenLai" class="form-control form-control-sm" list="danhSachTen" autocomplete="off" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Khách mua</label>
                <input type="text" name="TenKhach" class="form-control form-control-sm" list="danhSachTen" autocomplete="off" />
            </div>
            <div class="col-md-1">
                <label class="form-label small">SC</label>
                <input type="number" step="0.5" name="SoCon" class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">SL (kg)</label>
                <input type="number" step="0.1" name="SoLuong" class="form-control form-control-sm" required />
            </div>
            <div class="col-md-1">
                <label class="form-label small">Giá</label>
                <input type="number" name="Gia" class="form-control form-control-sm" required />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Thành tiền</label>
                <input type="number" name="ThanhTien" class="form-control form-control-sm" placeholder="Tự tính" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Tiền trả lái</label>
                <input type="number" name="TienTraLai" value="0" class="form-control form-control-sm" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-plus"></i> Thêm
                </button>
            </div>
        </form>

        <datalist id="danhSachTen">
            @foreach (var ten in Model.DanhSachTenKhach)
            {
                <option value="@ten" />
            }
        </datalist>

        @if (Model.NoMoiHomNay.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover debt-entry-table excel-grid" data-static-order="true" data-image-review-url="/Home/GetImageImportRows?ngay=@todayIso&amp;loaiImport=NhapNoMoi">
                    <thead class="table-primary">
                        <tr>
                            <th>#</th>
                            <th>Lái</th>
                            <th data-no-sort="true">Khách mua</th>
                            <th class="text-end">SC</th>
                            <th class="text-end">SL Excel</th>
                            <th class="text-end">SL ảnh</th>
                            <th class="text-end">Giá</th>
                            <th class="text-end">Thành tiền</th>
                            <th class="text-end">Tiền trả lái</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int stt = 1; }
                        @foreach (var laiGroup in Model.NoMoiHomNay.GroupBy(g => g.TenLai ?? ""))
                        {
                            var lai = string.IsNullOrWhiteSpace(laiGroup.Key) ? "(chưa rõ lái)" : laiGroup.Key;
                            var laiItems = laiGroup.ToList();
                            <tr class="debt-lai-row">
                                <td colspan="11">
                                    <span class="fw-bold">Lái: @lai</span>
                                    <span class="text-muted ms-2">@laiItems.Count dòng</span>
                                </td>
                            </tr>

                            @foreach (var khachGroup in laiItems.GroupBy(g => string.IsNullOrWhiteSpace(g.TenKhach) ? "(chưa có khách mua)" : g.TenKhach))
                            {
                                var khachItems = khachGroup.ToList();
                                var khachName = khachGroup.Key;

                                @foreach (var gd in khachItems)
                                {
                                    var needsReview = string.IsNullOrWhiteSpace(gd.TenKhach);
                                    <tr class="giao-dich-row @(needsReview ? "needs-review" : "")"
                                        data-giao-dich-id="@gd.Id"
                                        data-ten-lai="@lai"
                                        data-ten-khach="@khachName"
                                        data-excel-quantity="@gd.SoLuong.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)">
                                        <td>@(stt++)</td>
                                        <td class="fw-semibold">@lai</td>
                                        <td>@(string.IsNullOrWhiteSpace(gd.TenKhach) ? "Chưa có" : gd.TenKhach)</td>
                                        <td class="text-end">@gd.SoCon.ToString("#,##0.#")</td>
                                        <td class="text-end excel-qty">@gd.SoLuong.ToString("#,##0.#")</td>
                                        <td class="text-end image-qty-cell" data-giao-dich-id="@gd.Id"><span class="text-muted">-</span></td>
                                        <td class="text-end">@gd.Gia.ToString("#,##0")</td>
                                        <td class="text-end fw-bold">@gd.ThanhTien.ToString("#,##0")</td>
                                        <td class="text-end">@gd.TienTraLai.ToString("#,##0")</td>
                                        <td>
                                            <span class="badge review-status-badge @(needsReview ? "bg-warning text-dark" : "bg-secondary")">
                                                @(needsReview ? "Cần khách" : "Chờ ảnh")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-warning btn-edit" data-id="@gd.Id" data-bs-toggle="modal" data-bs-target="#editModal">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <form asp-action="XoaGiaoDich" method="post" class="d-inline" onsubmit="return confirm('Xóa giao dịch này?')">
                                                    <input type="hidden" name="id" value="@gd.Id" />
                                                    <button type="submit" class="btn btn-outline-danger"><i class="bi bi-trash"></i></button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }

                                <tr class="debt-customer-total-row small">
                                    <td colspan="3" class="text-end">Cộng khách @khachName:</td>
                                    <td class="text-end">@khachItems.Sum(x => x.SoCon).ToString("#,##0.#")</td>
                                    <td class="text-end">@khachItems.Sum(x => x.SoLuong).ToString("#,##0.#")</td>
                                    <td class="text-end image-customer-total" data-ten-lai="@lai" data-ten-khach="@khachName">-</td>
                                    <td></td>
                                    <td class="text-end">@khachItems.Sum(x => x.ThanhTien).ToString("#,##0")</td>
                                    <td class="text-end">@khachItems.Sum(x => x.TienTraLai).ToString("#,##0")</td>
                                    <td colspan="2"></td>
                                </tr>
                            }

                            <tr class="table-info fw-bold small debt-lai-total-row">
                                <td colspan="3" class="text-end">Cộng lái @lai:</td>
                                <td class="text-end">@laiItems.Sum(x => x.SoCon).ToString("#,##0.#")</td>
                                <td class="text-end">@laiItems.Sum(x => x.SoLuong).ToString("#,##0.#")</td>
                                <td class="text-end image-lai-total" data-ten-lai="@lai">-</td>
                                <td></td>
                                <td class="text-end">@laiItems.Sum(x => x.ThanhTien).ToString("#,##0")</td>
                                <td class="text-end">@laiItems.Sum(x => x.TienTraLai).ToString("#,##0")</td>
                                <td colspan="2"></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold table-warning">
                            <td colspan="3" class="text-end">TỔNG CỘNG:</td>
                            <td class="text-end">@Model.NoMoiHomNay.Sum(g => g.SoCon).ToString("#,##0.#")</td>
                            <td class="text-end">@Model.NoMoiHomNay.Sum(g => g.SoLuong).ToString("#,##0.#")</td>
                            <td class="text-end image-grand-total">-</td>
                            <td></td>
                            <td class="text-end">@Model.NoMoiHomNay.Sum(g => g.ThanhTien).ToString("#,##0")</td>
                            <td class="text-end">@Model.NoMoiHomNay.Sum(g => g.TienTraLai).ToString("#,##0")</td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted fst-italic">Chưa có giao dịch nào trong ngày @today.ToString("dd/MM/yyyy")</p>
        }
    </div>

    <!-- TAB 2: TRẢ NỢ HÔM NAY -->
    <div class="tab-pane fade" id="tab-tra-no">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <h5 class="mb-0 text-success fw-bold">
                <i class="bi bi-cash-stack"></i> BẢNG TRẢ NỢ THEO KHÁCH - @today.ToString("dd/MM/yyyy")
            </h5>
            <button type="button" class="btn btn-success btn-sm ms-auto" id="btnSaveTraNoBang">
                <i class="bi bi-check-all"></i> Lưu các ô trả
            </button>
        </div>

        @if (Model.ThongKeNoTheoKhach.Any())
        {
            var cacNgayTra = Model.CacNgay;
            var tongNoTheoNgayTra = new Dictionary<DateTime, decimal>();
            var tongTraTheoNgayTra = new Dictionary<DateTime, decimal>();
            foreach (var d in cacNgayTra)
            {
                tongNoTheoNgayTra[d] = Model.ThongKeNoTheoKhach.Sum(tk => tk.ChiTietTheoNgay.ContainsKey(d) ? tk.ChiTietTheoNgay[d].No : 0);
                tongTraTheoNgayTra[d] = Model.ThongKeNoTheoKhach.Sum(tk => tk.ChiTietTheoNgay.ContainsKey(d) ? tk.ChiTietTheoNgay[d].Tra : 0);
            }

            <div class="table-responsive">
                <table class="table table-sm table-bordered table-hover excel-grid" id="traNoBang" style="font-size: 0.82rem;">
                    <thead>
                        <tr class="table-success text-center">
                            <th rowspan="2" style="min-width:30px; vertical-align:middle">#</th>
                            <th rowspan="2" data-no-sort="true" style="min-width:120px; vertical-align:middle">Khách hàng</th>
                            <th rowspan="2" style="min-width:80px; vertical-align:middle">Nợ cũ</th>
                            <th rowspan="2" style="min-width:110px; vertical-align:middle">Trả nợ cũ</th>
                            @foreach (var d in cacNgayTra)
                            {
                                <th colspan="2" class="@(d.Date == today.Date ? "table-warning" : "")">
                                    @d.ToString("dd-M")
                                </th>
                            }
                            <th rowspan="2" style="min-width:90px; vertical-align:middle" class="table-dark text-white">Tổng nợ</th>
                        </tr>
                        <tr class="table-success text-center">
                            @foreach (var d in cacNgayTra)
                            {
                                <th class="@(d.Date == today.Date ? "table-warning" : "")" style="min-width:70px">Nợ</th>
                                <th class="@(d.Date == today.Date ? "table-warning" : "")" style="min-width:96px">Trả</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @{ int stt2 = 1; }
                        @foreach (var tk in Model.ThongKeNoTheoKhach.OrderBy(x => x.TenKhach))
                        {
                            <tr class="@(tk.ConNo < 0 ? "table-success" : "")">
                                <td class="text-center">@(stt2++)</td>
                                <td class="fw-semibold text-nowrap">@tk.TenKhach</td>
                                <td class="text-end">@(tk.NoCu != 0 ? tk.NoCu.ToString("#,##0") : "")</td>
                                <td>
                                    <input type="number"
                                           step="1"
                                           min="0"
                                           class="form-control form-control-sm text-end tra-no-cu-input"
                                           value="@(tk.TraNoCu != 0 ? tk.TraNoCu.ToString("0") : "")"
                                           data-original="@(tk.TraNoCu != 0 ? tk.TraNoCu.ToString("0") : "")"
                                           data-ten-khach="@tk.TenKhach" />
                                </td>
                                @foreach (var d in cacNgayTra)
                                {
                                    var hasData = tk.ChiTietTheoNgay.ContainsKey(d);
                                    var no = hasData ? tk.ChiTietTheoNgay[d].No : 0;
                                    var tra = hasData ? tk.ChiTietTheoNgay[d].Tra : 0;
                                    var isToday = d.Date == today.Date;
                                    <td class="text-end @(isToday ? "table-warning" : "")">@(no != 0 ? no.ToString("#,##0") : "")</td>
                                    <td class="@(isToday ? "table-warning" : "")">
                                        <div class="debt-pay-cell">
                                            <input type="number"
                                                   min="0"
                                                   step="1"
                                                   class="form-control form-control-sm text-end tra-no-input"
                                                   value="@(tra != 0 ? tra.ToString("0") : "")"
                                                   data-original="@(tra != 0 ? tra.ToString("0") : "")"
                                                   data-ten-khach="@tk.TenKhach"
                                                   data-ngay="@d.ToString("yyyy-MM-dd")" />
                                            @if (isToday)
                                            {
                                                <div class="form-check debt-paid-full-check" title="Trả hết nợ phát sinh trong ngày đang chọn">
                                                    <input class="form-check-input debt-paid-full-toggle"
                                                           type="checkbox"
                                                           aria-label="Trả hết nợ trong ngày"
                                                           data-target-date="@d.ToString("yyyy-MM-dd")"
                                                           data-fill-amount="@no.ToString("0", System.Globalization.CultureInfo.InvariantCulture)"
                                                           @(no > 0 && tra >= no ? "checked" : "") />
                                                </div>
                                            }
                                        </div>
                                    </td>
                                }
                                <td class="text-end fw-bold @(tk.ConNo < 0 ? "text-success" : "text-danger")">
                                    @tk.ConNo.ToString("#,##0")
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold table-warning">
                            <td colspan="2" class="text-end">TỔNG:</td>
                            <td class="text-end">@Model.ThongKeNoTheoKhach.Sum(x => x.NoCu).ToString("#,##0")</td>
                            <td class="text-end text-success">@Model.ThongKeNoTheoKhach.Sum(x => x.TraNoCu).ToString("#,##0")</td>
                            @foreach (var d in cacNgayTra)
                            {
                                <td class="text-end">@(tongNoTheoNgayTra[d] != 0 ? tongNoTheoNgayTra[d].ToString("#,##0") : "")</td>
                                <td class="text-end text-success">@(tongTraTheoNgayTra[d] != 0 ? tongTraTheoNgayTra[d].ToString("#,##0") : "")</td>
                            }
                            <td class="text-end text-danger">@Model.ThongKeNoTheoKhach.Sum(x => x.ConNo).ToString("#,##0")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted fst-italic">Chưa có dữ liệu công nợ để nhập trả nợ.</p>
        }
    </div>

    <!-- TAB 3: BÁO CÁO CÔNG NỢ (dạng bảng giống file BÁO CÁO) -->
    <div class="tab-pane fade" id="tab-con-lai">
        <h5 class="mb-3 text-center text-danger fw-bold">
            <i class="bi bi-file-earmark-spreadsheet"></i> BÁO CÁO CÔNG NỢ NGÀY @Model.NgayHienTai.ToString("dd-M")
        </h5>

        @if (Model.ThongKeNoTheoKhach.Any())
        {
            var cacNgay = Model.CacNgay;
            var tongNoTheoNgay = new Dictionary<DateTime, decimal>();
            var tongTraTheoNgay = new Dictionary<DateTime, decimal>();
            var tongNoPhatSinhHomNay = Model.NoMoiHomNay.Sum(g => g.ThanhTien);
            var tongThuHoiHomNay = Model.NoTraHomNay.Sum(t => t.SoTienTra);
            foreach (var d in cacNgay)
            {
                tongNoTheoNgay[d] = Model.ThongKeNoTheoKhach.Sum(tk => tk.ChiTietTheoNgay.ContainsKey(d) ? tk.ChiTietTheoNgay[d].No : 0);
                tongTraTheoNgay[d] = Model.ThongKeNoTheoKhach.Sum(tk => tk.ChiTietTheoNgay.ContainsKey(d) ? tk.ChiTietTheoNgay[d].Tra : 0);
            }

            <div class="daily-summary-band mb-3">
                <div class="row g-2">
                    <div class="col-md-6">
                        <div class="daily-summary-item">
                            <div class="text-muted small">Nợ phát sinh mới hôm nay</div>
                            <div class="fw-bold text-danger">@tongNoPhatSinhHomNay.ToString("#,##0")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="daily-summary-item">
                            <div class="text-muted small">Nợ đã thu hồi hôm nay</div>
                            <div class="fw-bold text-success">@tongThuHoiHomNay.ToString("#,##0")</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-sm table-bordered table-hover" style="font-size: 0.82rem;">
                    <thead>
                        <!-- Row 1: group headers -->
                        <tr class="table-danger text-center">
                            <th rowspan="2" style="min-width:30px; vertical-align:middle">#</th>
                            <th rowspan="2" data-no-sort="true" style="min-width:120px; vertical-align:middle">Khách hàng</th>
                            <th rowspan="2" style="min-width:80px; vertical-align:middle">Nợ cũ</th>
                            @foreach (var d in cacNgay)
                            {
                                <th colspan="2" class="@(d.Date == DateTime.Today ? "table-warning" : "")">
                                    @d.ToString("dd-M")
                                </th>
                            }
                            <th rowspan="2" style="min-width:90px; vertical-align:middle" class="table-dark text-white">Tổng nợ</th>
                        </tr>
                        <!-- Row 2: Nợ/Trả sub-headers -->
                        <tr class="table-danger text-center">
                            @foreach (var d in cacNgay)
                            {
                                <th class="@(d.Date == DateTime.Today ? "table-warning" : "")" style="min-width:70px">Nợ</th>
                                <th class="@(d.Date == DateTime.Today ? "table-warning" : "")" style="min-width:70px">Trả</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @{ int stt3 = 1; }
                        @foreach (var tk in Model.ThongKeNoTheoKhach.OrderBy(x => x.TenKhach))
                        {
                            <tr class="@(tk.ConNo < 0 ? "table-success" : "")">
                                <td class="text-center">@(stt3++)</td>
                                <td class="fw-semibold text-nowrap">@tk.TenKhach</td>
                                <td class="text-end">@(tk.NoCu != 0 ? tk.NoCu.ToString("#,##0") : "")</td>
                                @foreach (var d in cacNgay)
                                {
                                    var hasData = tk.ChiTietTheoNgay.ContainsKey(d);
                                    var no = hasData ? tk.ChiTietTheoNgay[d].No : 0;
                                    var tra = hasData ? tk.ChiTietTheoNgay[d].Tra : 0;
                                    var isToday = d.Date == DateTime.Today;
                                    <td class="text-end @(isToday ? "table-warning" : "")">@(no != 0 ? no.ToString("#,##0") : "")</td>
                                    <td class="text-end @(isToday ? "table-warning" : "") @(tra != 0 ? "text-success" : "")">@(tra != 0 ? tra.ToString("#,##0") : "")</td>
                                }
                                <td class="text-end fw-bold @(tk.ConNo < 0 ? "text-success" : "text-danger")">
                                    @tk.ConNo.ToString("#,##0")
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold table-warning">
                            <td colspan="2" class="text-end">TỔNG:</td>
                            <td class="text-end">@Model.ThongKeNoTheoKhach.Sum(x => x.NoCu).ToString("#,##0")</td>
                            @foreach (var d in cacNgay)
                            {
                                <td class="text-end">@(tongNoTheoNgay[d] != 0 ? tongNoTheoNgay[d].ToString("#,##0") : "")</td>
                                <td class="text-end text-success">@(tongTraTheoNgay[d] != 0 ? tongTraTheoNgay[d].ToString("#,##0") : "")</td>
                            }
                            <td class="text-end text-danger">@Model.ThongKeNoTheoKhach.Sum(x => x.ConNo).ToString("#,##0")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted fst-italic">Chưa có dữ liệu công nợ.</p>
        }
    </div>

    <!-- TAB 4: HOÀN THIỆN DỮ LIỆU -->
    <div class="tab-pane fade" id="tab-hoan-thien">

        <!-- Header controls -->
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <span class="fw-semibold"><i class="bi bi-layers"></i> Gộp &amp; hoàn thiện — @today.ToString("dd/MM/yyyy")</span>
            <select id="dpLoai" class="form-select form-select-sm" style="width:160px">
                <option value="NhapNoMoi">Nhập nợ mới</option>
                <option value="TraNoHomNay">Trả nợ hôm nay</option>
            </select>
            <select id="dpNguon" class="form-select form-select-sm" style="width:140px">
                <option value="BH1">Bán hàng 1</option>
                <option value="BH2">Bán hàng 2</option>
            </select>
            <div class="ms-auto d-flex gap-2 align-items-center">
                <span id="dpSaveMsg" class="small d-none"></span>
                <button class="btn btn-sm btn-outline-secondary" id="dpBtnReset" type="button">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                </button>
                <button class="btn btn-sm btn-success" id="dpBtnSave" type="button" disabled>
                    <i class="bi bi-check-circle"></i> Xác nhận &amp; Lưu
                </button>
            </div>
        </div>

        <!-- Upload inputs (compact row) -->
        <div class="row g-2 mb-3">
            <div class="col-12 col-md-6">
                <div class="border rounded p-2 d-flex align-items-center gap-2">
                    <i class="bi bi-file-earmark-excel text-primary fs-5 flex-shrink-0"></i>
                    <label class="btn btn-sm btn-outline-primary mb-0 flex-shrink-0" for="dpExcelFile">
                        <i class="bi bi-upload"></i> Excel
                    </label>
                    <input type="file" id="dpExcelFile" accept=".xlsx,.xls" class="d-none" />
                    <span id="dpExcelStatus" class="small text-muted text-truncate flex-grow-1">Chưa có file</span>
                    <button class="btn btn-sm btn-link text-muted p-0 flex-shrink-0" id="dpExcelReset" title="Xóa Excel">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div id="dpExcelMsg" class="px-2 py-1 small d-none mt-1"></div>
            </div>
            <div class="col-12 col-md-6">
                <div class="border rounded p-2 d-flex align-items-center gap-2">
                    <i class="bi bi-camera text-success fs-5 flex-shrink-0"></i>
                    <label class="btn btn-sm btn-outline-success mb-0 flex-shrink-0" for="dpImageFiles">
                        <i class="bi bi-upload"></i> Ảnh
                    </label>
                    <input type="file" id="dpImageFiles" accept="image/*" multiple class="d-none" />
                    <span id="dpImageStatus" class="small text-muted text-truncate flex-grow-1">Chưa có ảnh</span>
                    <button class="btn btn-sm btn-link text-muted p-0 flex-shrink-0" id="dpImageReset" title="Xóa Ảnh">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div id="dpImageMsg" class="px-2 py-1 small d-none mt-1"></div>
            </div>
        </div>

        <!-- Unified merge table -->
        <div id="dpMergeTable" style="overflow-x:auto; max-height:560px; overflow-y:auto;">
            <div class="p-5 text-center text-muted">
                <i class="bi bi-layers fs-1 d-block opacity-25 mb-2"></i>
                Upload Excel và/hoặc Ảnh để xem dữ liệu gộp
            </div>
        </div>

        <!-- Summary bar -->
        <div id="dpSummaryBar" class="d-none mt-3 p-2 rounded border small d-flex flex-wrap gap-2 align-items-center">
            <strong>Tổng hợp:</strong>
            <span id="dpSumMatched" class="badge bg-success">0 khớp</span>
            <span id="dpSumDiff" class="badge bg-warning text-dark">0 lệch</span>
            <span id="dpSumExcelOnly" class="badge bg-secondary">0 chỉ Excel</span>
            <span id="dpSumImageOnly" class="badge bg-info text-dark">0 chỉ Ảnh</span>
        </div>
    </div>
</div>

<!-- MODAL: XÓA TOÀN BỘ DỮ LIỆU -->
<div class="modal fade" id="deleteAllModal" tabindex="-1" aria-labelledby="deleteAllModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-danger">
            <form asp-action="XoaToanBoDuLieu" method="post" id="deleteAllForm">
                <input type="hidden" name="ngay" value="@todayIso" />
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteAllModalLabel">
                        <i class="bi bi-exclamation-triangle"></i> Xóa toàn bộ dữ liệu
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger">
                        Thao tác này sẽ xóa vĩnh viễn toàn bộ giao dịch, trả nợ, khách hàng,
                        dữ liệu import và ảnh đã tải lên. Không thể hoàn tác.
                    </div>
                    <label for="deleteAllConfirmation" class="form-label">
                        Nhập chính xác <strong>XOA TOAN BO</strong> để xác nhận:
                    </label>
                    <input type="text"
                           class="form-control"
                           id="deleteAllConfirmation"
                           name="xacNhan"
                           autocomplete="off"
                           spellcheck="false"
                           required />
                    <div class="form-text">Chỉ nút xóa mới được bật khi nội dung xác nhận chính xác.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger" id="deleteAllSubmit" disabled>
                        <i class="bi bi-trash3"></i> Xóa toàn bộ dữ liệu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL: IMPORT EXCEL -->
<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="ImportExcel" method="post" enctype="multipart/form-data">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-upload"></i> Import Excel</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Chọn file Excel (.xlsx)</label>
                        <input type="file" name="file" class="form-control" accept=".xlsx,.xls" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ngày giao dịch (cho file hàng ngày)</label>
                        <input type="date" name="ngayGiaoDich" value="@today.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="alert alert-info small mb-0">
                        <strong>Hỗ trợ 2 loại file:</strong><br />
                        <b>1. File hàng ngày:</b> KH | SC | SL | Giá | T.Tiền | TiềnLái<br />
                        <b>2. BÁO CÁO công nợ:</b> Tự động nhận diện, import khách hàng + nợ cũ + giao dịch
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-upload"></i> Import</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const modal = document.getElementById('deleteAllModal');
        const confirmation = document.getElementById('deleteAllConfirmation');
        const submit = document.getElementById('deleteAllSubmit');

        function updateDeleteButton() {
            submit.disabled = confirmation.value.trim() !== 'XOA TOAN BO';
        }

        confirmation.addEventListener('input', updateDeleteButton);
        modal.addEventListener('shown.bs.modal', function () {
            confirmation.focus();
        });
        modal.addEventListener('hidden.bs.modal', function () {
            confirmation.value = '';
            updateDeleteButton();
        });
    });
</script>

